<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.lilicould.liliblog.mapper.ArticleMapper">

    <resultMap id="BaseResultMap" type="cn.lilicould.liliblog.pojo.entity.Article">
        <id property="id" column="id" />
        <result property="title" column="title" />
        <result property="slug" column="slug" />
        <result property="summary" column="summary" />
        <result property="content" column="content" />
        <result property="contentHtml" column="content_html" />
        <result property="coverImage" column="cover_image" />
        <result property="status" column="status" />
        <result property="viewCount" column="view_count" />
        <result property="categoryId" column="category_id" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <result property="createBy" column="create_by" />
        <result property="updateBy" column="update_by" />
        <result property="deleted" column="deleted" />
    </resultMap>

    <resultMap id="articleVOMap" type="cn.lilicould.liliblog.pojo.dto.response.ArticleDetailsVO">
        <!-- 根对象字段 -->
        <id property="id" column="a_id" />
        <result property="title" column="title" />
        <result property="slug" column="a_slug" />
        <result property="summary" column="summary" />
        <result property="coverImage" column="cover_image" />
        <result property="status" column="a_status" />
        <result property="contentHtml" column="content_html" />
        <result property="viewCount" column="view_count" />
        <result property="likeCount" column="like_count" />
        <result property="commentCount" column="comment_count" />

        <result property="updateTime" column="update_time" />
        <result property="createTime" column="create_time" />

        <!-- updater -->
        <association property="updater" javaType="cn.lilicould.liliblog.pojo.dto.response.UserInfo">
            <id property="id" column="u_updater_id" />
            <result property="username" column="u_updater_username" />
            <result property="nickname" column="u_updater_nickname" />
            <result property="avatar" column="u_updater_avatar" />
            <result property="role" column="u_updater_role" />
            <result property="status" column="u_updater_status" />
            <result property="lastLoginTime" column="u_updater_last_login_time" />
        </association>

        <!-- creator -->
        <association property="creator" javaType="cn.lilicould.liliblog.pojo.dto.response.UserInfo">
            <id property="id" column="u_creator_id" />
            <result property="username" column="u_creator_username" />
            <result property="nickname" column="u_creator_nickname" />
            <result property="avatar" column="u_creator_avatar" />
            <result property="role" column="u_creator_role" />
            <result property="status" column="u_creator_status" />
            <result property="lastLoginTime" column="u_creator_last_login_time" />
        </association>

        <!-- category -->
        <association property="category" javaType="cn.lilicould.liliblog.pojo.dto.response.CategoryVO">
            <id property="id" column="c_id" />
            <result property="name" column="c_name" />
            <result property="slug" column="c_slug" />
            <result property="description" column="c_description" />
            <result property="sortOrder" column="c_sort_order" />
        </association>

        <!-- tags -->
        <collection property="tags" ofType="cn.lilicould.liliblog.pojo.dto.response.TagVO">
            <id property="id" column="t_id" />
            <result property="name" column="t_name" />
            <result property="color" column="t_color" />
        </collection>
    </resultMap>

    <sql id="Base_Column_List">
        id,title,slug,summary,content,content_html,
        cover_image,status,view_count,category_id,create_time,
        update_time,create_by,update_by,deleted
    </sql>

    <select id="selectArticleVOById" resultType="cn.lilicould.liliblog.pojo.dto.response.ArticleDetailsVO">

    </select>
</mapper>
