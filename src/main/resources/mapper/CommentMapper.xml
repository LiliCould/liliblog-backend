<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lilicould.blog.dao.CommentMapper">
    <select id="selectAll" resultType="com.lilicould.blog.entity.Comment">
        SELECT * FROM comment
    </select>

    <select id="selectById" resultType="com.lilicould.blog.entity.Comment">
        SELECT * FROM comment WHERE id = #{id} AND status = 'APPROVED'
    </select>

    <select id="selectByArticleId" resultType="com.lilicould.blog.entity.Comment">
        SELECT * FROM comment WHERE article_id = #{articleId} AND status = 'APPROVED'
    </select>

    <select id="selectByParentId" resultType="com.lilicould.blog.entity.Comment">
        SELECT * FROM comment WHERE parent_id = #{parentId} AND status = 'APPROVED'
    </select>

    <insert id="insert">

    </insert>

</mapper>